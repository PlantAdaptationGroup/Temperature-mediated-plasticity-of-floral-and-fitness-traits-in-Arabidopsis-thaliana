  "DraII-6" = "◇",
  "DraIV 1-8" = "✖",
  "DraIV 3-7" = "✚",
  "DraIV 5-12" = "✦",
  "Hovdala-2" = "✪",
  "Lag1-2" = "★",
  "Lag1-6" = "☆",
  "Le-0" = "✿",
  "Ler-0" = "❖",
  "Lis-1" = "⬢",
  "LL-0" = "⬡",
  "Mer-6" = "⬟",
  "Mitterberg-1-181" = "⬠",
  "Or-0" = "◉",
  "Qui-0" = "◍",
  "Rue3-1-31" = "◔",
  "Se-0" = "◑",
  "Sij-2" = "◐",
  "Tha-1" = "◒",
  "Ts-1" = "◓",
  "TueSB30-3" = "◕",
  "Tu-KS-7" = "✤",
  "UKSW06-226" = "✥",
  "UKSW06-257" = "❉",
  "Wt-5" = "✸",
  "Xan-1" = "✷",
  "Wa-1" = "✹"
