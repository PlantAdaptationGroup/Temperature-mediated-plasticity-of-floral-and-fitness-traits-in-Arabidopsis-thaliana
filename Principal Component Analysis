library(readxl)
library(dplyr)
library(tidyr)
library(ggplot2)
library(factoextra)
library(openxlsx)
library(ggrepel)
library(ggforce)
library(svglite)
library(grid)
library(gridExtra)


# === USER INPUTS ===
file_path <- 
output_folder <- 
dir.create(output_folder, showWarnings = FALSE, recursive = TRUE)
temps <- c("Temp17", "Temp20", "Temp24", "Temp27")

selected_traits <- c("days_to_bolting",
                     "days_to_10_siliques",
                     "FD",
                     "seeds_per_silique",
                     "single_seed_weight_mg",
                     "Number_of_seeds_Total",
                     "number_of_flowers")

# === 1. COMBINED PCA ===
data_all <- lapply(temps, function(sheet) {
  df <- read_excel(file_path, sheet = sheet)
  df <- df %>% drop_na()
  df$Temperature <- sheet
  df
}) %>% bind_rows()


meta_all <- data_all[, c("#pot", "Accession", "Temperature")]

traits_all <- data_all %>% 
  select(all_of(selected_traits)) %>% 
  select(where(is.numeric))

traits_all <- traits_all[, apply(traits_all, 2, function(x) sd(x) > 0)]
rownames(traits_all) <- paste(meta_all$Accession, meta_all$Temperature, meta_all$`#pot`, sep = "_")

pca_all <- prcomp(traits_all, scale. = TRUE)

scores_all <- as.data.frame(pca_all$x)
scores_all$Accession <- meta_all$Accession
scores_all$Temperature <- meta_all$Temperature
loadings <- as.data.frame(pca_all$rotation)
loadings$Trait <- rownames(loadings)

# Rename traits for plotting
loadings$Trait <- recode(loadings$Trait,
                         "days_to_bolting" = "FT (days)",
                         "days_to_10_siliques" = "ESDT (days)",
                         "FD" = "FD [mm]",
                         "seeds_per_silique" = "SS",
                         "single_seed_weight_mg" = "SSW [mg]",
                         "Number_of_seeds_Total" = "SN",
                         "number_of_flowers" = "FN"
)


temp_colors <- c("Temp17" = "blue", "Temp20" = "green", "Temp24" = "orange", "Temp27" = "red")
alpha_value <- 0.1

scores_all_with_iqr <- scores_all %>%
  group_by(Temperature) %>%
  mutate(
    pc1_iqr_lower = quantile(PC1, 0.25) - 1.5 * IQR(PC1),
    pc1_iqr_upper = quantile(PC1, 0.75) + 1.5 * IQR(PC1),
    pc2_iqr_lower = quantile(PC2, 0.25) - 1.5 * IQR(PC2),
    pc2_iqr_upper = quantile(PC2, 0.75) + 1.5 * IQR(PC2)
  ) %>%
  ungroup()

